{
  "manifest_version": 3,
  "name": "Yoru Reader Extension",
  "version": "1.3.2",
  "description": "Japanese text parsing with Yoru Reader",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "js/background-worker.js"
  },
  "action": {
    "default_popup": "views/widget.html",
    "default_title": "Yoru Reader Extension"
  },
  "options_ui": {
    "page": "views/settings.html",
    "open_in_tab": true
  },
  "permissions": [
    "contextMenus",
    "offscreen",
    "scripting",
    "storage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/ajb.js"
      ],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "css/*",
        "views/*",
        "js/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}